datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Business {
  id               String            @id @default(uuid())
  name             String
  slug             String            @unique
  logo             String?
  phone            String?
  email            String?
  address          String?
  currency         String            @default("USD")
  taxConfig        Json?             // { taxName: "VAT", rate: 15 }
  settings         Json?             // Custom metadata settings
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?

  subscription     Subscription?
  branches         Branch[]
  users            User[]
  categories       Category[]
  brands           Brand[]
  units            Unit[]
  products         Product[]
  customers        Customer[]
  suppliers        Supplier[]
  sales            Sale[]
  purchases        Purchase[]
  payments         Payment[]
  saleReturns      SaleReturn[]
  purchaseReturns  PurchaseReturn[]
  expenseCategories ExpenseCategory[]
  expenses         Expense[]
  incomeCategories  IncomeCategory[]
  incomes           Income[]
  stockTransfers   StockTransfer[]
  auditLogs        AuditLog[]
  notifications    Notification[]
  openingStocks    OpeningStock[]
}

model Subscription {
  id           String    @id @default(uuid())
  businessId   String    @unique
  business     Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  plan         String    @default("FREE") // FREE, BASIC, PREMIUM, ENTERPRISE
  status       String    @default("ACTIVE") // ACTIVE, EXPIRED, CANCELLED
  startDate    DateTime  @default(now())
  endDate      DateTime
  userLimit    Int       @default(3)
  branchLimit  Int       @default(1)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Branch {
  id         String     @id @default(uuid())
  businessId String
  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  phone      String?
  address    String?
  isMain     Boolean    @default(false)
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  deletedAt  DateTime?

  users                User[]
  productStocks        ProductStock[]
  batches              Batch[]
  sales                Sale[]
  purchases            Purchase[]
  expenses             Expense[]
  incomes              Income[]
  stockTransfersSource StockTransfer[] @relation("SourceBranch")
  stockTransfersTarget StockTransfer[] @relation("TargetBranch")
  customers            Customer[]
  openingStocks        OpeningStock[]
  payments             Payment[]
}

model User {
  id           String     @id @default(uuid())
  businessId   String
  business     Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branchId     String?
  branch       Branch?    @relation(fields: [branchId], references: [id], onDelete: SetNull)
  name         String
  email        String     @unique
  passwordHash String
  role         String     @default("CASHIER") // SUPER_ADMIN, OWNER, MANAGER, CASHIER, ACCOUNTANT, STOREKEEPER, SALESPERSON, DELIVERY
  phone        String?
  isActive     Boolean    @default(true)
  allowedDeviceId String?
  deviceName      String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  sales      Sale[]
  purchases  Purchase[]
  expenses   Expense[]
  incomes    Income[]
  auditLogs  AuditLog[]
  enteredOpeningStocks  OpeningStock[]  @relation("EnteredBy")
  approvedOpeningStocks OpeningStock[]  @relation("ApprovedBy")
  requestedTransfers    StockTransfer[] @relation("RequestedTransfers")
  approvedTransfers     StockTransfer[] @relation("ApprovedTransfers")
  receivedTransfers     StockTransfer[] @relation("ReceivedTransfers")
  payments              Payment[]
}

model Category {
  id         String     @id @default(uuid())
  businessId String
  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  deletedAt  DateTime?

  products   Product[]
}

model Brand {
  id         String     @id @default(uuid())
  businessId String
  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  deletedAt  DateTime?

  products   Product[]
}

model Unit {
  id         String     @id @default(uuid())
  businessId String
  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  deletedAt  DateTime?

  products   Product[]
}

model Product {
  id             String         @id @default(uuid())
  businessId     String
  business       Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  categoryId     String?
  category       Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brandId        String?
  brand          Brand?         @relation(fields: [brandId], references: [id], onDelete: SetNull)
  unitId         String?
  unit           Unit?          @relation(fields: [unitId], references: [id], onDelete: SetNull)
  name           String
  sku            String?
  barcode        String?
  description    String?
  costPrice      Float          @default(0)
  sellingPrice   Float          @default(0)
  wholesalePrice Float          @default(0)
  alertQuantity  Int            @default(5)
  image          String?
  batchTracking  Boolean        @default(false)
  expiryTracking Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  productStocks       ProductStock[]
  batches             Batch[]
  saleItems           SaleItem[]
  purchaseItems       PurchaseItem[]
  stockTransferItems  StockTransferItem[]
  openingStocks       OpeningStock[]
}

model ProductStock {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  quantity  Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, branchId])
}

model Batch {
  id          String    @id @default(uuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  branchId    String
  branch      Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  batchNumber String
  quantity    Float     @default(0)
  costPrice   Float?
  sellingPrice Float?
  expiryDate  DateTime?
  manufacturingDate DateTime?
  rackNumber        String?
  supplierId        String?
  supplier          Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
}

model Customer {
  id           String           @id @default(uuid())
  businessId   String
  business     Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branchId     String?
  branch       Branch?          @relation(fields: [branchId], references: [id], onDelete: SetNull)
  name         String
  email        String?
  phone        String?
  address      String?
  customerType String           @default("RETAIL") // RETAIL, WHOLESALE
  creditLimit  Float            @default(0)
  balance      Float            @default(0) // Debt owed by customer to us
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  deletedAt    DateTime?

  sales        Sale[]
  ledgers      CustomerLedger[]
  payments     Payment[]
}

model CustomerLedger {
  id          String   @id @default(uuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type        String   // SALE, PAYMENT, RETURN, ADJUSTMENT
  reference   String?
  debit       Float    @default(0) // Amount customer owes us (increases balance)
  credit      Float    @default(0) // Amount customer pays us (decreases balance)
  balance     Float    @default(0) // Running balance
  description String?
  createdAt   DateTime @default(now())
}

model Supplier {
  id          String           @id @default(uuid())
  businessId  String
  business    Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?
  balance     Float            @default(0) // Debt we owe to supplier
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?

  purchases   Purchase[]
  ledgers     SupplierLedger[]
  openingStocks OpeningStock[]
  batches     Batch[]
  payments    Payment[]
}

model SupplierLedger {
  id          String   @id @default(uuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  type        String   // PURCHASE, PAYMENT, RETURN, ADJUSTMENT
  reference   String?
  debit       Float    @default(0) // What we paid supplier (decreases balance)
  credit      Float    @default(0) // What we purchased from supplier (increases balance)
  balance     Float    @default(0) // Running balance we owe
  description String?
  createdAt   DateTime @default(now())
}

model Sale {
  id            String       @id @default(uuid())
  businessId    String
  business      Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branchId      String
  branch        Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customerId    String?
  customer      Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoiceNumber String       @unique
  status        String       @default("COMPLETED") // COMPLETED, DRAFT, ON_HOLD, RETURNED
  subtotal      Float        @default(0)
  discount      Float        @default(0)
  tax           Float        @default(0)
  total         Float        @default(0)
  paidAmount    Float        @default(0)
  paymentStatus String       @default("PAID") // PAID, PARTIAL, UNPAID
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  saleItems   SaleItem[]
  payments    Payment[]
  saleReturns SaleReturn[]
}

model SaleItem {
  id          String   @id @default(uuid())
  saleId      String
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  batchNumber String?
  quantity    Float    @default(1)
  costPrice   Float    @default(0)
  price       Float    @default(0) // Selling price per unit after discount
  discount    Float    @default(0) // Unit-level discount
  tax         Float    @default(0) // Unit-level tax
  total       Float    @default(0) // quantity * price
}

model Purchase {
  id             String     @id @default(uuid())
  businessId     String
  business       Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branchId       String
  branch         Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  supplierId     String
  supplier       Supplier   @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchaseNumber String     @unique
  status         String     @default("RECEIVED") // ORDERED, RECEIVED, CANCELLED
  subtotal       Float      @default(0)
  discount       Float      @default(0)
  tax            Float      @default(0)
  total          Float      @default(0)
  paidAmount     Float      @default(0)
  paymentStatus  String     @default("PAID") // PAID, PARTIAL, UNPAID
  notes          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  deletedAt      DateTime?

  purchaseItems   PurchaseItem[]
  payments        Payment[]
  purchaseReturns PurchaseReturn[]
}

model PurchaseItem {
  id          String    @id @default(uuid())
  purchaseId  String
  purchase    Purchase  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  batchNumber String?
  expiryDate  DateTime?
  quantity    Float     @default(1)
  price       Float     @default(0) // Buying price per unit
  total       Float     @default(0)
}

model Payment {
  id            String    @id @default(uuid())
  businessId    String
  business      Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  saleId        String?
  sale          Sale?     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  purchaseId    String?
  purchase      Purchase? @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  supplierId    String?
  supplier      Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  branchId      String?
  branch        Branch?   @relation(fields: [branchId], references: [id], onDelete: SetNull)
  userId        String?   // receivedBy or sentBy
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  amount        Float
  method        String    @default("CASH") // CASH, CARD, QR, BANK_TRANSFER, CREDIT
  reference     String?   // Reference number
  receiptNumber String?   // Receipt or voucher number
  remarks       String?   // Notes/remarks
  type          String    @default("RECEIVED") // RECEIVED or SENT
  createdAt     DateTime  @default(now())
}

model SaleReturn {
  id           String           @id @default(uuid())
  businessId   String
  business     Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  saleId       String
  sale         Sale             @relation(fields: [saleId], references: [id], onDelete: Cascade)
  returnNumber String           @unique
  refundAmount Float            @default(0)
  notes        String?
  createdAt    DateTime         @default(now())
  items        SaleReturnItem[]
}

model SaleReturnItem {
  id           String     @id @default(uuid())
  saleReturnId String
  saleReturn   SaleReturn @relation(fields: [saleReturnId], references: [id], onDelete: Cascade)
  productId    String
  quantity     Float
  price        Float
  total        Float
}

model PurchaseReturn {
  id           String               @id @default(uuid())
  businessId   String
  business     Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  purchaseId   String
  purchase     Purchase             @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  returnNumber String               @unique
  refundAmount Float                @default(0)
  notes        String?
  createdAt    DateTime             @default(now())
  items        PurchaseReturnItem[]
}

model PurchaseReturnItem {
  id               String         @id @default(uuid())
  purchaseReturnId String
  purchaseReturn   PurchaseReturn @relation(fields: [purchaseReturnId], references: [id], onDelete: Cascade)
  productId        String
  quantity         Float
  price            Float
  total            Float
}

model ExpenseCategory {
  id         String    @id @default(uuid())
  businessId String
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  expenses   Expense[]
}

model Expense {
  id          String          @id @default(uuid())
  businessId  String
  business    Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branchId    String
  branch      Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  categoryId  String
  category    ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Float
  reference   String?         // Voucher code or receipt number
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?
}

model IncomeCategory {
  id         String    @id @default(uuid())
  businessId String
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  incomes    Income[]
}

model Income {
  id          String          @id @default(uuid())
  businessId  String
  business    Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branchId    String
  branch      Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  categoryId  String
  category    IncomeCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Float
  reference   String?         // Voucher code or receipt number
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?
}

model StockTransfer {
  id             String              @id @default(uuid())
  businessId     String
  business       Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sourceBranchId String
  sourceBranch   Branch              @relation("SourceBranch", fields: [sourceBranchId], references: [id], onDelete: Cascade)
  targetBranchId String
  targetBranch   Branch              @relation("TargetBranch", fields: [targetBranchId], references: [id], onDelete: Cascade)
  status         String              @default("PENDING") // PENDING, APPROVED, REJECTED, DISPATCHED, RECEIVED
  notes          String?
  remarks        String?
  requestedById  String?
  requestedBy    User?               @relation("RequestedTransfers", fields: [requestedById], references: [id], onDelete: SetNull)
  approvedById   String?
  approvedBy     User?               @relation("ApprovedTransfers", fields: [approvedById], references: [id], onDelete: SetNull)
  receivedById   String?
  receivedBy     User?               @relation("ReceivedTransfers", fields: [receivedById], references: [id], onDelete: SetNull)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  items          StockTransferItem[]
}

model StockTransferItem {
  id         String        @id @default(uuid())
  transferId String
  transfer   StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  productId  String
  product    Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity   Float
}

model AuditLog {
  id          String    @id @default(uuid())
  businessId  String
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  role        String?
  branchId    String?
  warehouseId String?
  action      String    // CREATE, UPDATE, DELETE, LOGIN, LOGOUT, etc.
  module      String    // PRODUCT, SALE, PURCHASE, USER, etc.
  details     String?
  oldValue    Json?
  newValue    Json?
  deviceInfo  String?
  ipAddress   String?
  createdAt   DateTime  @default(now())
}

model Notification {
  id         String   @id @default(uuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  title      String
  message    String
  type       String   @default("STOCK") // STOCK, PAYMENT, SYSTEM, INFO
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model OpeningStock {
  id                String    @id @default(uuid())
  businessId        String
  business          Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branchId          String
  branch            Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  warehouseId       String?
  productId         String
  product           Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  // Stock Information
  quantity          Float     @default(0)
  unitType          String    // pcs, box, strip, tablet, bottle, kg, gram, liter, ml
  
  // Pricing
  purchaseRate      Float     @default(0)
  sellingPrice      Float     @default(0)
  mrp               Float     @default(0)
  totalValue        Float     @default(0) // Quantity * purchaseRate
  
  // Batch Information
  batchNumber       String?
  expiryDate        DateTime?
  manufacturingDate DateTime?
  rackNumber        String?
  supplierId        String?
  supplier          Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  
  // Audit Information
  openingDate       DateTime  @default(now())
  remarks           String?
  enteredById       String
  enteredBy         User      @relation("EnteredBy", fields: [enteredById], references: [id], onDelete: Cascade)
  approvedById      String?
  approvedBy        User?     @relation("ApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  approvalStatus    String    @default("PENDING") // PENDING, APPROVED, REJECTED
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}
